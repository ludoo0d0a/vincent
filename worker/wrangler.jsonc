{
  // Cloudflare Worker: Gemini proxy for the Vincent app.
  // The Gemini key lives only here (Worker Secret GEMINI_API_KEY), never in the APK.
  // Provision + deploy via: ./scripts/setup-ai-proxy.sh (geoking-tools).
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vin-cent-ai",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "observability": { "enabled": true },

  // Public, non-secret config. Secrets (GEMINI_API_KEY) are set with `wrangler secret put`.
  "vars": {
    "FIREBASE_PROJECT_ID": "vincent-499318",
    "FIREBASE_PROJECT_NUMBER": "847279428684",
    "WEB_CLIENT_ID": "847279428684-2qlpipcu0a3u0pmrndbahmllgk7hor44.apps.googleusercontent.com",
    "GEMINI_MODEL": "gemini-3.5-flash",
    "DAILY_QUOTA": "50",
    "CACHE_TTL_SECONDS": "86400",
    "ENFORCE_APP_CHECK": "true",
    "ENFORCE_AUTH": "true",
    "ENFORCE_APP_CHECK": "false"
  },

  // Per-user daily quota counters + response cache. The id is filled in by
  // setup-ai-proxy.sh after `wrangler kv namespace create AI_KV`.
  "kv_namespaces": [
    { "binding": "AI_KV", "id": "e5941372c1d54f1280b53bcb8041f970" }
  ]
}
