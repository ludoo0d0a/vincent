<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Foreground service permissions for AR screen recording (required for Android 14+). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ARCore is optional: the app still installs on non-AR devices; the feature
         flag + runtime ArCoreApk check hide/disable the AR screen there. -->
    <uses-feature android:name="android.hardware.camera.ar" android:required="false" />

    <!-- Required on Android 11+ so SpeechRecognizer can see the recognition service. -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="Vincent"
        android:supportsRtl="true"
        android:theme="@style/Theme.Vincent">

        <!-- Preload the Google Code Scanner module at install time. -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="barcode_ui" />

        <!-- ARCore optional: Play Services for AR installs on demand, not required. -->
        <meta-data
            android:name="com.google.ar.core"
            android:value="optional" />

        <!-- Foreground service that holds the MediaProjection while recording AR video. -->
        <service
            android:name="fr.geoking.vincent.ar.ScreenRecordService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <activity
            android:name="fr.geoking.vincent.MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode|density|fontScale"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
