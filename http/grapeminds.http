> {%
    client.test("200 OK", function () {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
%}

### Get producer detail with wines
GET {{baseUrl}}/producers/{{producerId}}?include_wines=1
Authorization: Bearer {{apiKey}}
Accept-Language: {{language}}
Accept: application/json

> {%
    client.test("200 OK", function () {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("producer detail has id", function () {
        client.assert(response.body.data != null && response.body.data.id != null, "missing producer id");
    });
%}

