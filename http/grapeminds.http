### grapeminds Public API v1 — IntelliJ HTTP Client tests
#
# Mirrors GrapeMindsClient.kt (androidMain/.../data/GrapeMindsClient.kt).
# Base + language come from http-client.env.json; the API key lives in the
# gitignored http-client.private.env.json ({{apiKey}}).
#
# Run: select the "grapeminds" environment (top-right run gutter), then run a
# request or "Run All Requests in File". Requests are chained — running top to
# bottom captures a wineId / producerId / regionId for the follow-up calls.
#
# Auth: Authorization: Bearer {{apiKey}} + Accept-Language: {{language}}.

### List wines (first page) — captures {{wineId}}
GET {{baseUrl}}/wines?page=1&per_page=5
Authorization: Bearer {{apiKey}}
Accept-Language: {{language}}
Accept: application/json

> {%
    client.test("200 OK", function () {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("data is an array", function () {
        client.assert(Array.isArray(response.body.data), "response.data is not an array");
    });
    client.test("meta pagination present", function () {
        client.assert(response.body.meta != null, "missing meta");
        client.assert(response.body.meta.per_page <= 100, "per_page must be <= 100 (MAX_PER_PAGE)");
    });
    if (response.body.data && response.body.data.length > 0) {
        client.global.set("wineId", response.body.data[0].id);
        client.log("captured wineId=" + response.body.data[0].id);
    }
%}

### List wines filtered by color=red — every row is red
GET {{baseUrl}}/wines?per_page=10&color=red
Authorization: Bearer {{apiKey}}
Accept-Language: {{language}}
Accept: application/json

> {%
    client.test("200 OK", function () {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("all rows are red", function () {
        (response.body.data || []).forEach(function (w) {
            client.assert(w.color === "red", "found non-red color: " + w.color);
        });
    });
%}

### Search wines — q must be >= 3 chars (client-side guard in searchWines)
GET {{baseUrl}}/wines/search?q=margaux&limit=20
Authorization: Bearer {{apiKey}}
Accept-Language: {{language}}
Accept: application/json

> {%
    client.test("200 OK", function () {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("has data array", function () {
        client.assert(Array.isArray(response.body.data), "response.data is not an array");
    });
%}

### Get wine detail by id (uses {{wineId}} from the first request)
GET {{baseUrl}}/wines/{{wineId}}
Authorization: Bearer {{apiKey}}
Accept-Language: {{language}}
Accept: application/json

> {%
    client.test("200 OK", function () {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("detail id matches requested wineId", function () {
        client.assert(response.body.data != null, "missing data envelope");
        client.assert(String(response.body.data.id) === client.global.get("wineId"),
            "detail id does not match wineId");
    });
    if (response.body.data && response.body.data.region) {
        client.global.set("regionId", response.body.data.region.id);
        client.log("captured regionId=" + response.body.data.region.id);
    }
    if (response.body.data && response.body.data.producer) {
        client.global.set("producerId", response.body.data.producer.id);
        client.log("captured producerId=" + response.body.data.producer.id);
    }
%}

### List producers — captures {{producerId}} (fallback if none from wine detail)
GET {{baseUrl}}/producers?page=1&per_page=15
Authorization: Bearer {{apiKey}}
Accept-Language: {{language}}
Accept: application/json

> {%
    client.test("200 OK", function () {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("data is an array", function () {
        client.assert(Array.isArray(response.body.data), "response.data is not an array");
    });
    if (!client.global.get("producerId") && response.body.data && response.body.data.length > 0) {
        client.global.set("producerId", response.body.data[0].id);
    }
%}

### Search producers — search param requires >= 2 chars
GET {{baseUrl}}/producers?per_page=15&search=ch
