### Region insights
GET {{proxyBaseUrl}}/v1/grapeminds/region-insights/{{regionId}}?lang={{language}}
Authorization: Bearer {{firebaseIdToken}}
X-Firebase-AppCheck: {{appCheckToken}}
Accept-Language: {{language}}
Accept: application/json

> {%
    client.test("200 or 401", function () {
        client.assert([200, 401].indexOf(response.status) >= 0,
            "unexpected status " + response.status);
    });
    if (response.status === 200) {
        client.test("has summary or is generating", function () {
            var b = response.body;
            client.assert(
                (typeof b.summary === "string" && b.summary.length > 0) || b.generating === true,
                "expected summary or generating"
            );
        });
    }
%}

### Drinking period
GET {{proxyBaseUrl}}/v1/grapeminds/drinking-periods/{{wineId}}?lang={{language}}
Authorization: Bearer {{firebaseIdToken}}
X-Firebase-AppCheck: {{appCheckToken}}
Accept-Language: {{language}}
Accept: application/json

> {%
    client.test("200 or 401", function () {
        client.assert([200, 401].indexOf(response.status) >= 0,
            "unexpected status " + response.status);
    });
    if (response.status === 200) {
        client.test("has drink window or is generating", function () {
            var b = response.body;
            client.assert(
                (b.from != null && b.to != null) || b.generating === true,
                "expected from/to or generating"
            );
        });
    }
%}

### Auth guard — missing Firebase tokens rejected
GET {{proxyBaseUrl}}/v1/grapeminds/wines?per_page=1
Accept-Language: {{language}}
Accept: application/json

> {%
    client.test("rejected without auth", function () {
        client.assert([401, 403].indexOf(response.status) >= 0,
            "expected 401/403 without tokens, got " + response.status);
    });
%}
