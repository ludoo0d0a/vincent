### Get producer detail with wines
GET {{proxyBaseUrl}}/v1/grapeminds/producers/{{producerId}}?include_wines=1
Authorization: Bearer {{firebaseIdToken}}
X-Firebase-AppCheck: {{appCheckToken}}
Accept-Language: {{language}}
Accept: application/json

> {%
    client.test("200 or 401", function () {
        client.assert([200, 401].indexOf(response.status) >= 0,
            "unexpected status " + response.status);
    });
    if (response.status === 200) {
        client.test("producer detail has id", function () {
            client.assert(response.body.data != null && response.body.data.id != null,
                "missing producer id");
        });
    }
%}

