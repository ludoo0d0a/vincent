### grapeminds Public API v1 — via Cloudflare Worker proxy
#
# Worker forwards GET /v1/grapeminds/* → grapeminds API (worker/src/index.ts).
# Production app path for catalogue lists; search/detail also work through proxy.
# Pair: grapeminds.http (direct Bearer apiKey).
#
# Environment: grapeminds — proxyBaseUrl + firebaseIdToken + appCheckToken in private env.

### List wines — captures {{wineId}}
GET {{proxyBaseUrl}}/v1/grapeminds/wines?page=1&per_page=5
Authorization: Bearer {{firebaseIdToken}}
X-Firebase-AppCheck: {{appCheckToken}}
Accept-Language: {{language}}
Accept: application/json

> {%
    client.test("200 or 401 (stale tokens)", function () {
        client.assert([200, 401].indexOf(response.status) >= 0,
            "unexpected status " + response.status);
    });
    if (response.status === 200) {
        client.test("paginated envelope", function () {
            client.assert(Array.isArray(response.body.data), "data is not an array");
            client.assert(response.body.meta != null, "missing meta");
        });
        if (response.body.data.length > 0) {
            client.global.set("wineId", response.body.data[0].id);
        }
    }
%}

### List wines filtered by color=red
GET {{proxyBaseUrl}}/v1/grapeminds/wines?per_page=10&color=red
Authorization: Bearer {{firebaseIdToken}}
X-Firebase-AppCheck: {{appCheckToken}}
Accept-Language: {{language}}
Accept: application/json

> {%
    client.test("200 or 401", function () {
        client.assert([200, 401].indexOf(response.status) >= 0,
            "unexpected status " + response.status);
    });
    if (response.status === 200) {
        client.test("all rows are red", function () {
            (response.body.data || []).forEach(function (w) {
                client.assert(w.color === "red", "found non-red color: " + w.color);
            });
        });
    }
%}

### Search wines
GET {{proxyBaseUrl}}/v1/grapeminds/wines/search?q=margaux&limit=20
Authorization: Bearer {{firebaseIdToken}}
X-Firebase-AppCheck: {{appCheckToken}}
Accept-Language: {{language}}
Accept: application/json

> {%
    client.test("200 or 401", function () {
        client.assert([200, 401].indexOf(response.status) >= 0,
            "unexpected status " + response.status);
    });
    if (response.status === 200) {
        client.test("has data array", function () {
            client.assert(Array.isArray(response.body.data), "data is not an array");
        });
    }
%}

### Get wine detail — uses {{wineId}}
GET {{proxyBaseUrl}}/v1/grapeminds/wines/{{wineId}}
Authorization: Bearer {{firebaseIdToken}}
X-Firebase-AppCheck: {{appCheckToken}}
Accept-Language: {{language}}
Accept: application/json

> {%
    client.test("200 or 401", function () {
        client.assert([200, 401].indexOf(response.status) >= 0,
            "unexpected status " + response.status);
    });
    if (response.status === 200) {
        client.test("detail id matches wineId", function () {
            client.assert(response.body.data != null, "missing data");
            client.assert(String(response.body.data.id) === client.global.get("wineId"),
                "id mismatch");
        });
        if (response.body.data.region) {
            client.global.set("regionId", response.body.data.region.id);
        }
        if (response.body.data.producer) {
            client.global.set("producerId", response.body.data.producer.id);
        }
    }
%}

### List producers — captures {{producerId}}
GET {{proxyBaseUrl}}/v1/grapeminds/producers?page=1&per_page=15
Authorization: Bearer {{firebaseIdToken}}
X-Firebase-AppCheck: {{appCheckToken}}
Accept-Language: {{language}}
Accept: application/json

> {%
    client.test("200 or 401", function () {
        client.assert([200, 401].indexOf(response.status) >= 0,
            "unexpected status " + response.status);
    });
    if (response.status === 200) {
        client.test("data is an array", function () {
            client.assert(Array.isArray(response.body.data), "data is not an array");
        });
        if (!client.global.get("producerId") && response.body.data.length > 0) {
            client.global.set("producerId", response.body.data[0].id);
        }
    }
%}

